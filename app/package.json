{
  "name": "wind-forecast-monitor",
  "private": true,
  "version": "1.0.0",
  "packageManager": "npm@11.5.2",
  "workspaces": [
    "packages/client",
    "packages/shared"
  ],
  "scripts": {
    "dev": "npm run dev -w @wind-forecast/client",
    "build": "npm run build -w @wind-forecast/client",
    "lint": "eslint . --max-warnings=0",
    "test": "npm run test -w @wind-forecast/client",
    "test:e2e": "playwright test",
    "typecheck": "npm run typecheck -w @wind-forecast/client && npm run typecheck -w @wind-forecast/shared",
    "data:refresh": "tsx scripts/refresh-static-data.ts",
    "format": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@playwright/test": "^1.53.0",
    "@types/node": "^24.12.0",
    "eslint": "^9.23.0",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0"
  }
}
